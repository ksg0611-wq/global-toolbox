# frontend/.env.production
#
# 📌 프로덕션 빌드 전용 환경 변수 (Vite)
#
# - 이 파일은 `npm run build` 시에만 적용됩니다.
# - VITE_ 접두사가 붙은 변수만 클라이언트 번들에 포함됩니다.
# - 민감 정보(API 키 등)는 절대 이 파일에 작성하지 마세요.
#
# 프론트엔드 배포 후 백엔드 CORS를 제한하려면:
#   npx wrangler secret put ALLOWED_ORIGIN
#   → 입력값: https://<your-pages-domain>.pages.dev

VITE_API_BASE_URL=https://global-toolbox-backend.ksg0611.workers.dev
